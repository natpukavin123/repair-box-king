                                    <a x-show="r.is_fully_paid" :href="'/repairs/' + r.id + '/invoice'" target="_blank" @click.stop class="text-[10px] text-gray-400 hover:text-purple-600 flex items-center gap-0.5 ml-auto"><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg> Invoice</a>
                                </div>
