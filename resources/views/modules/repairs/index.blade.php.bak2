                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                            <span class="font-medium" x-text="selectedCust?.name"></span>
                            <button @click="createForm.customer_id = null; selectedCust = null" class="text-primary-400 hover:text-red-500 ml-1">&times;</button>
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Device Brand</label>
                        <input x-model="createForm.device_brand" type="text" class="form-input-custom" placeholder="e.g. Samsung, Apple">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Device Model</label>
                        <input x-model="createForm.device_model" type="text" class="form-input-custom" placeholder="e.g. Galaxy S24, iPhone 15">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">IMEI / Serial No.</label>
                        <input x-model="createForm.imei" type="text" class="form-input-custom" placeholder="Device IMEI or serial number">
                    </div>
