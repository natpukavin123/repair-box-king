APP_NAME=RepairBox
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.up.railway.app

APP_TIMEZONE=UTC

LOG_CHANNEL=stderr
LOG_LEVEL=error

# ── Database (set from Railway MySQL service) ─────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# ── Session / Cache / Queue (all use DB — no Redis needed) ────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database

FILESYSTEM_DISK=local

# ── Image Storage (Cloudflare R2 / S3) ───────────────────────────────────────
# Set IMAGE_DISK=s3 to use Cloudflare R2 for all image uploads.
# Images will be stored as full URLs in the database.
IMAGE_DISK=public
#IMAGE_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=
AWS_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
AWS_URL=https://pub-<hash>.r2.dev
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Mail (configure as needed) ────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
